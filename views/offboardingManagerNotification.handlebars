<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <meta name="color-scheme" content="light dark" />
    <title>Manager Offboarding Notification</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      body, table, td, p, a, li, blockquote {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }
      table, td {
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
      }
      img {
        -ms-interpolation-mode: bicubic;
        border: 0;
        outline: none;
        text-decoration: none;
      }
      .container {
        font-family: 'Plus Jakarta Sans', Arial, sans-serif;
        color: black;
        width: 100%;
        background: #FFFFFF;
      }
      .content {
        max-width: 500px;
        width: 100%;
        min-height: 200px;
        padding: 24px 50px;
        margin: 0 auto;
        box-sizing: border-box;
      }
      .mittarv_header {
        width: 100%;
        height: 79px;
        line-height: 79px;
        background-color: #E7F3F8;
        text-align: center;
      }
      .mittarv_header > img {
        padding-top: 20px;
        vertical-align: middle;
      }
      .illustration {
        width: 100%;
        text-align: center;
        padding: 24px 0 16px;
      }
      .illustration > img {
        width: 140px;
        height: 140px;
      }
      .heading {
        width: 100%;
        color: #454754;
        font-size: 24px;
        font-weight: 700;
        line-height: 34px;
        margin-bottom: 8px;
        text-align: center;
      }
      .subheading {
        width: 100%;
        color: #167E7E;
        font-size: 16px;
        font-weight: 500;
        line-height: 24px;
        margin-bottom: 24px;
        text-align: center;
      }
      .body_text {
        width: 100%;
        text-align: left;
        color: #454754;
        font-size: 16px;
        font-weight: 400;
        line-height: 26px;
        margin-bottom: 16px;
      }
      .cta_container {
        width: 100%;
        text-align: center;
        margin: 32px 0;
      }
      .cta_button {
        display: inline-block;
        text-decoration: none;
        background-color: #167E7E;
        padding: 12px 24px;
        border: none;
        border-radius: 64px;
        color: #FFFFFF !important;
        font-size: 16px;
        font-weight: 600;
        font-family: 'Plus Jakarta Sans', Arial, sans-serif;
        text-align: center;
        line-height: 1.2;
      }
      .regards_box {
        margin-top: 48px;
        border-top: 2px solid #C7C9D1;
        padding-top: 24px;
        text-align: center;
      }
      .regards {
        font-size: 16px;
        font-weight: 400;
        line-height: 28px;
        color: #454754;
        margin-bottom: 16px;
      }
      .team_mittarv {
        font-size: 16px;
        font-weight: 700;
        line-height: 28px;
        color: #167E7E;
      }
      .zero_life_infinity {
        font-size: 16px;
        font-weight: 400;
        line-height: 28px;
        color: #167E7E;
      }
      .mittarv_footer {
        width: 100%;
        background-color: #E7F3F8;
        padding: 48px 0px;
        text-align: center;
      }
      .available_on {
        font-size: 14px;
        font-weight: 700;
        line-height: 20px;
        color: #8F92A3;
        margin-bottom: 8px;
      }
      .platforms {
        font-size: 16px;
        font-weight: 600;
        line-height: 24px;
        color: #454754;
        margin-bottom: 24px;
      }
      .social_icons_box {
        font-size: 14px;
        font-weight: 700;
        line-height: 20px;
        color: #8F92A3;
        margin-bottom: 52px;
      }
      .follow_us_on {
        margin-bottom: 8px;
      }
      .social_icons > a {
        display: inline-block;
        margin-right: 6px;
        border-radius: 50%;
      }
      .social_icons > a > img {
        display: block;
      }
      .inquiries {
        text-align: center;
      }
      .inquiries > div {
        font-size: 16px;
        font-weight: 400;
        line-height: 28px;
        color: #454754;
      }
      .inquiries > a {
        font-size: 16px;
        font-weight: 700;
        line-height: 28px;
        color: #454754;
        text-decoration: underline;
      }
      @media only screen and (max-width: 600px) {
        .content {
          max-width: 100% !important;
          width: 100% !important;
          padding: 20px 15px !important;
        }
        .heading { font-size: 20px !important; line-height: 28px !important; }
        .subheading { font-size: 14px !important; line-height: 20px !important; }
        .body_text { font-size: 14px !important; line-height: 22px !important; }
      }
    </style>
  </head>

  <body style="margin: 0; padding: 0; background-color: #FFFFFF;">
    <div class="container">
      <div class="mittarv_header">
        <img
          src="https://mittarvtesting.blob.core.windows.net/mittarv-icons/mittarv-logo-horizontal-coloured.png"
          alt="Mitt Arv"
          width="137"
          height="40"
        />
      </div>

      <div class="illustration">
        <img
          src="https://mittarvtesting.blob.core.windows.net/mittarv-icons/hrms_sad_puzzle_image.png"
          alt="Manager offboarding illustration"
        />
      </div>

      <div class="content">
        <div class="heading">
          Manager Offboarding Pending
        </div>

        <div class="subheading">
          Offboarding has been initiated for <strong>{{employeeName}} </strong>
        </div>

        <div class="body_text">
          This employee is currently assigned as a manager to one or more team members.
        </div>

        <div class="body_text">
          Please review and update reporting lines before completing the clearance process.
        </div>

        <div class="cta_container">
          <a
            href="{{redirectUrl}}"
            class="cta_button"
            style="display: inline-block; text-decoration: none; background-color: #033348; padding: 12px 24px; border-radius: 64px; color: #FFFFFF; font-size: 16px; font-weight: 600; font-family: 'Plus Jakarta Sans', Arial, sans-serif;"
          >Review Offboarding Details</a>
        </div>

        <div class="regards_box">
          <div class="regards">Warmest regards,</div>
          <div class="team_mittarv">Team Mitt Arv</div>
          <div class="zero_life_infinity">Zero — Life — Infinity</div>
        </div>
      </div>

      <div class="mittarv_footer">
        <div class="social_icons_box">
          <div class="follow_us_on">Follow Us On</div>
          <div class="social_icons">
            <a href="https://www.linkedin.com/company/mittarv/" target="_blank" rel="noopener noreferrer">
              <img src="https://mittarvtesting.blob.core.windows.net/mittarv-icons/Linkedin.png" width="36" height="36" alt="LinkedIn" />
            </a>
            <a href="https://www.facebook.com/mittarv/?_rdr" target="_blank" rel="noopener noreferrer">
              <img src="https://mittarvtesting.blob.core.windows.net/mittarv-icons/Facebook.png" width="36" height="36" alt="Facebook" />
            </a>
            <a href="https://medium.com/mittarv" target="_blank" rel="noopener noreferrer">
              <img src="https://mittarvtesting.blob.core.windows.net/mittarv-icons/Medium.png" width="36" height="36" alt="Medium" />
            </a>
            <a href="https://x.com/Mitt_Arv" target="_blank" rel="noopener noreferrer">
              <img src="https://mittarvtesting.blob.core.windows.net/mittarv-icons/X.png" width="36" height="36" alt="X" />
            </a>
          </div>
        </div>

        <div class="inquiries">
          <div>For any inquiries, kindly reach out to us at</div>
          <a href="mailto:support@mittarv.com" style="color: #454754; font-family:500;">support@mittarv.com</a>
        </div>
      </div>
    </div>
  </body>
</html>
