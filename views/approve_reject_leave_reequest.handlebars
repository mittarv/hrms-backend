<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>{{subject}}</title>
    <style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    body, table, td, p, a, li, blockquote {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
        font-family: Arial, sans-serif;
    }
    
    table, td {
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
        border-collapse: collapse;
    }
    
    img {
        -ms-interpolation-mode: bicubic;
        border: 0;
        outline: none;
        text-decoration: none;
        max-width: 100%;
        height: auto;
        display: block;
    }
    
    .container {
        font-family: Arial, sans-serif;
        color: #454754;
        width: 100%;
        background: #FFFFFF;
        margin: 0 auto;
        max-width: 600px;
    }
    
    .header-bg {
        background-color: #E7F3F8;
        padding: 20px 0;
    }
    
    .hero-icon-container {
        width: 120px;
        height: 120px;
        margin: 0 auto;
        position: relative;
    }
    
    .email-icon-bg {
        width: 80px;
        height: 60px;
        background: #FFFFFF;
        border: 2px solid #454754;
        border-radius: 8px;
        margin: 20px auto 0;
        position: relative;
    }
    
    .pointer-triangle {
        width: 0;
        height: 0;
        border-left: 15px solid transparent;
        border-right: 15px solid transparent;
        border-top: 12px solid #454754;
        margin: 16px auto 0;
    }
    
    .notification-circle {
        width: 40px;
        height: 40px;
        background: #5DADE2;
        border-radius: 50%;
        position: absolute;
        top: 0;
        right: 0;
    }
    
    .approve-button {
        background-color: #033348;
        color: #FFFFFF;
        border: none;
        padding: 12px 24px;
        border-radius: 32px;
        font-size: 14px;
        font-weight: 600;
        font-family: Arial, sans-serif;
        text-decoration: none;
        display: inline-block;
        text-align: center;
        min-width: 140px;
        margin: 0 6px 12px 0;
    }
    
    .reject-button {
        background-color: #FFFFFF;
        color: #454754;
        border: 2px solid #2FBCBC;
        padding: 10px 24px;
        border-radius: 32px;
        font-size: 14px;
        font-weight: 600;
        font-family: Arial, sans-serif;
        text-decoration: none;
        display: inline-block;
        text-align: center;
        min-width: 140px;
        margin: 0 0 12px 6px;
    }
    
    .social-icon {
        width: 36px;
        height: 36px;
        margin: 0 6px;
        display: inline-block;
        border-radius: 50%;
    }
    
    /* Mobile Responsiveness */
    @media only screen and (max-width: 600px) {
        .approve-button, .reject-button {
            display: block;
            width: 100%;
            max-width: 280px;
            margin: 6px auto;
            padding: 14px 24px;
            font-size: 15px;
        }
        
        .social-icon {
            width: 32px;
            height: 32px;
            margin: 0 4px;
        }
        
        .hero-icon-container {
            width: 100px;
            height: 100px;
        }
        
        .email-icon-bg {
            width: 70px;
            height: 50px;
        }
        
        .notification-circle {
            width: 35px;
            height: 35px;
        }
        
        .pointer-triangle {
            border-left: 12px solid transparent;
            border-right: 12px solid transparent;
            border-top: 10px solid #454754;
            margin: 12px auto 0;
        }
    }
    </style>
</head>
<body style="margin: 0; padding: 0; background-color: #FFFFFF;">
    <!-- Main Container -->
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #FFFFFF;">
        
        <!-- Full Width Header -->
        <tr>
            <td style="background-color: #E7F3F8; padding: 20px 0;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                    <tr>
                        <td align="center">
                            <img src="https://mittarvtesting.blob.core.windows.net/mittarv-icons/mittarv-logo-horizontal-coloured.png" alt="Mittarv Logo" style="max-width: 137px; height: auto; margin: 0 auto;" />
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        
        <!-- Content Container -->
        <tr>
            <td align="center">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" class="container" style="max-width: 600px;">
                    
                    <!-- Hero Section with Icon -->
                    <tr>
                        <td style="padding: 40px 0 20px 0; text-align: center; background: #FFFFFF;">
                            <div style="width: 120px; height: 120px; margin: 0 auto; position: relative;">
                                <!-- Email Icon Container -->
                                <div style="width: 80px; height: 60px; background: #FFFFFF; border: 2px solid #454754; border-radius: 8px; margin: 20px auto 0; position: relative;">
                                    <!-- Triangle Pointer -->
                                    <div style="width: 0; height: 0; border-left: 15px solid transparent; border-right: 15px solid transparent; border-top: 12px solid #454754; margin: 16px auto 0;"></div>
                                </div>
                                <!-- Notification Circle -->
                                <div style="width: 40px; height: 40px; background: #5DADE2; border-radius: 50%; position: absolute; top: 0; right: 0;"></div>
                            </div>
                        </td>
                    </tr>
                    
                    <!-- Content -->
                    <tr>
                        <td style="padding: 0 32px;">
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                                <tr>
                                    <td style="color: #454754; font-size: 16px; font-weight: 400; line-height: 24px; text-align: left;">
                                        <p style="margin: 0 0 16px 0;">Hey <span style="font-weight: 600; color: #454754;">{{employeeName}}</span>,</p>
                                        <p style="margin: 0 0 16px 0;">Your request for {{leaveType}} on {{leaveDate}} has been {{#if isApproved}}approved!{{else}}rejected!{{/if}}</p>
                                        </p>
                                    </td>
                                </tr>

                                {{!-- redirect note --}}
                                {{#unless isApproved}}
                                <tr>
                                    <td style="color: #8F92A3; font-size: 14px; font-weight: 400; line-height: 20px; text-align: center; padding: 0 0 40px 0;">
                                        If you'd like to discuss this further or explore alternatives, please contact your manager.
                                    </td>
                                </tr>
                                {{/unless}}name="color-scheme" content="light dark" />

                                <!-- Divider -->
                                <tr>
                                    <td style="border-bottom: 1px solid #E1E8ED; padding: 0 0 32px 0;"></td>
                                </tr>
                                
                                <!-- Regards -->
                                <tr>
                                    <td style="text-align: center; padding: 0 0 40px 0;">
                                        <div style="font-size: 16px; font-weight: 400; line-height: 24px; color: #454754; margin-bottom: 8px;">Warmest regards,</div>
                                        <div style="font-size: 16px; font-weight: 700; line-height: 24px; color: #167E7E; margin-bottom: 4px;">Team Mitt Arv</div>
                                        <div style="font-size: 16px; font-weight: 400; line-height: 24px; color: #167E7E;">Zero — Life — Infinity</div>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        
        <!-- Full Width Footer -->
        <tr>
            <td style="background-color: #E7F3F8; padding: 40px 32px; text-align: center;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                    <!-- Social Icons -->
                    <tr>
                        <td style="padding: 0 0 32px 0;">
                            <div style="font-size: 14px; font-weight: 700; line-height: 20px; color: #8F92A3; margin-bottom: 16px;">Follow Us On</div>
                            <div style="text-align: center;">
                                <a href="https://www.linkedin.com/company/mittarv/" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin: 0 6px;">
                                    <img src="https://mittarvtesting.blob.core.windows.net/mittarv-icons/Linkedin.png" alt="LinkedIn" class="social-icon" style="width: 36px; height: 36px; border-radius: 50%;" />
                                </a>
                                <a href="https://www.facebook.com/mittarv/?_rdr" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin: 0 6px;">
                                    <img src="https://mittarvtesting.blob.core.windows.net/mittarv-icons/Facebook.png" alt="Facebook" class="social-icon" style="width: 36px; height: 36px; border-radius: 50%;" />
                                </a>
                                <a href="https://medium.com/mittarv" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin: 0 6px;">
                                    <img src="https://mittarvtesting.blob.core.windows.net/mittarv-icons/Medium.png" alt="Medium" class="social-icon" style="width: 36px; height: 36px; border-radius: 50%;" />
                                </a>
                                <a href="https://x.com/Mitt_Arv" target="_blank" rel="noopener noreferrer" style="display: inline-block; margin: 0 6px;">
                                    <img src="https://mittarvtesting.blob.core.windows.net/mittarv-icons/X.png" alt="X (Twitter)" class="social-icon" style="width: 36px; height: 36px; border-radius: 50%;" />
                                </a>
                            </div>
                        </td>
                    </tr>
                    

                    <tr>
                        <td style="text-align: center;">
                            <div style="font-size: 16px; font-weight: 400; line-height: 24px; color: #454754; margin-bottom: 4px;">For any inquiries, kindly reach out to us at</div>
                            <a href="mailto:hr@mittarv.com" style="font-size: 16px; font-weight: 700; line-height: 24px; color: #454754; text-decoration: none;">hr@mittarv.com</a>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>