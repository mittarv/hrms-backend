<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <meta name="color-scheme" content="light dark" />
    <title>Document</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      .button { width: 180px; height: 30px; background-color: rgba(253, 147, 32,
      0.8); border-radius: 20px; border: none; margin-top: 10px; margin-bottom:
      15px; color: white; }
    </style>
  </head>

  <body>
    <div
      style="padding:0;margin:0;box-sizing:border-box;background: #033348;padding:2% 4%;padding-bottom: 4%;"
    >
      <img
        style="height: 60px;width: 60px;padding-left:4%;margin-top:1%;margin-bottom:1.5%;"
        src="https://mittarvtesting.blob.core.windows.net/mittarv-icons/mittarv_logo_white_tm.png"
      />

      <div
        style="background: #054A68;padding:2% 4%;margin-bottom:2%;border-radius: 5px;text-align:center"
      >
        <img
          style="margin-top:1%;margin-bottom:1.5%; height:43px"
          src="https://mittarvtesting.blob.core.windows.net/mittarv-icons/welcome.png"
        />
        <h2
          style="font-size:2vh;color:white;font-weight:700;font-family: 'Plus Jakarta Sans', sans-serif;font-size: 14px;letter-spacing: 1.5%;"
        >
          Thank you for your response</h2>
        <h2
          style="font-size:2vh;color:white;font-weight:700;font-family: 'Plus Jakarta Sans', sans-serif;font-size: 14px;letter-spacing: 1.5%;"
        >
          Dear
          {{TCname}}</h2>
        <p
          style="color:white;font-family: 'Plus Jakarta Sans', sans-serif;font-weight:400;font-size:12px;letter-spacing: 1.5%;"
        >

          Thank you for providing an update regarding
          {{username}}. We really appreciate you taking time out for filling out
          the form and backing the user.
          <br /><br />
          Continue building your legacy on Mitt Arv.
          <br /><br />
        </p>
        <button class="button">
          <a
            href="{{redirectUrl}}"
            target="_blank"
            style="color:white;font-family: 'Plus Jakarta Sans', sans-serif;font-weight:400;font-size:12px;letter-spacing: 1.5%;margin: auto; text-decoration:none"
          >
            Sign In
          </a>
        </button>
        <p
          style="font-size: 12px;font-family: 'Plus Jakarta Sans', sans-serif;color:white;font-weight:400;letter-spacing: 1.5%;margin-top: 30px;"
        >
          Best,<br />Team<span
            style=" font-size: 12px;font-family: 'Plus Jakarta Sans', sans-serif; color: #84B5D2;font-weight: 700;letter-spacing: 1.5%;"
          >
            Mitt Arv</span><br />
          <b>Zero - Life - Infinity</b>
        </p>
        <div
          style="height:2px;background:#033348;margin-top: 2.5%; margin-bottom: 2.5%; margin-left: -4%; margin-right: -4%;"
        >
        </div>
        <p
          style="font-family: 'Plus Jakarta Sans', sans-serif;font-size: 12px;color: white;letter-spacing: 1.5%;"
        >
          For any inquiries, kindly reach out to us at<br />
          support@mittarv.com
        </p>
      </div>
    </div>
  </body>

</html>