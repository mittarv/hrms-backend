{
  "name": "mittarv-backend",
  "version": "1.0.0",
  "description": "this backend is for mittarv",
  "main": "index.ts",
  "nodemonConfig": {
    "watch": [
      "*.js",
      "*.ts"
    ],
    "ignore": [
      "node_modules/*",
      "test/*",
      "*.hbs"
    ],
    "ext": "js,ts",
    "delay": 500
  },
  "scripts": {
    "start": "node dist/index.js",
    "start:dev": "npm install && tsc --outDir dist && node -r newrelic dist/index.js",
    "server": "nodemon index.ts",
    "dev": "nodemon index.ts",
    "build": "tsc --outDir dist && shx cp -r views dist/ && shx cp -r keys dist/ && shx cp config/*.p8 dist/config/",
    "test": "jest",
    "migrate": "node -e \"require('./dist/migration').migrate()\"",
    "migrate:output": "node -e \"require('./dist/migration').migrateSingle('output')\"",
    "migrate:payments": "node -e \"require('./dist/migration').migrateSingle('payments')\"",
    "migrate:main": "node -e \"require('./dist/migration').migrateSingle('main')\"",
    "migrate:rollback": "node -e \"require('./dist/migration').migrateRollback()\"",
    "migrate:rollback:output": "node -e \"require('./dist/migration').migrateRollbackSingle('output')\"",
    "migrate:rollback:payments": "node -e \"require('./dist/migration').migrateRollbackSingle('payments')\"",
    "migrate:rollback:main": "node -e \"require('./dist/migration').migrateRollbackSingle('main')\"",
    "migrate:reset": "node -e \"require('./dist/migration').migrateReset()\"",
    "migrate:reset:output": "node -e \"require('./dist/migration').migrateResetSingle('output')\"",
    "migrate:reset:payments": "node -e \"require('./dist/migration').migrateResetSingle('payments')\"",
    "migrate:reset:main": "node -e \"require('./dist/migration').migrateResetSingle('main')\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mittarv/backend.git"
  },
  "author": "mittarv.com",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mittarv/backend/issues"
  },
  "homepage": "https://github.com/mittarv/backend#readme",
  "dependencies": {
    "@azure/event-hubs": "^5.11.4",
    "@azure/service-bus": "^7.9.5",
    "@azure/storage-blob": "^12.16.0",
    "@react-pdf/pdfkit": "^4.0.0",
    "applicationinsights": "^3.2.1",
    "axios": "^1.12.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "country-state-city": "^3.2.1",
    "crypto-js": "^4.2.0",
    "currency-symbol-map": "^5.1.0",
    "dotenv": "^16.0.2",
    "express": "^4.22.1",
    "firebase-admin": "^12.1.1",
    "google-auth-library": "^9.11.0",
    "googleapis": "^146.0.0",
    "helmet": "^6.0.1",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.0.2",
    "mysql2": "^3.9.8",
    "newrelic": "^13.6.2",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "node-rsa": "^1.1.1",
    "nodemailer": "^7.0.11",
    "nodemailer-express-handlebars": "^6.0.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.8.0",
    "redis": "^4.7.0",
    "sequelize": "^6.21.4",
    "sequelize-cli": "^6.4.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "chai": "^4.3.6",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "jest": "^30.2.0",
    "mocha": "^10.0.0",
    "nodemon": "^3.1.7",
    "shx": "^0.4.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0"
  }
}
