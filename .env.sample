# ==================== SERVER CONFIGURATION ====================
# GitHub Variable: PORT
PORT=YOUR_SERVER_PORT_HERE

# GitHub Variable: NODE_ENV
NODE_ENV=YOUR_NODE_ENV_HERE

# GitHub Variable: IP
IP=YOUR_SERVER_IP_HERE

# ==================== JWT & AUTH CONFIGURATION ====================
# GitHub Secret: SECRET_KEY (SENSITIVE)
SECRET_KEY=your-jwt-secret-key-here

# GitHub Secret: GOOGLE_CLIENT_ID (SENSITIVE)
GOOGLE_CLIENT_ID=your-google-client-id-here

# GitHub Secret: GOOGLE_CLIENT_SECRET (SENSITIVE)
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# GitHub Secret: REFRESH_TOKEN_SECRET (SENSITIVE)
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-here

# ==================== TMS LOGIN CONFIGURATION (Optional) ====================
# Comma-separated list of super admin emails
TMS_SUPER_ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Comma-separated list of allowed email domains (defaults to mittarv.com if not set)
TMS_ALLOWED_DOMAINS=mittarv.com

# ==================== SMTP CONFIGURATION ====================
# GitHub Variable: SMTP_HOST
SMTP_HOST="smtp.gmail.com"

# GitHub Variable: SMTP_PORT
SMTP_PORT=YOUR_SMTP_PORT_NUMBER_HERE

# GitHub Variable: SMTP_USER
SMTP_USER="YOUR_SMTP_USER_HERE"

# GitHub Secret: SMTP_PASS (SENSITIVE)
SMTP_PASS="YOUR_SMTP_PASSWORD_HERE"

# ==================== HRMS EMAIL CONFIGURATION ====================
# GitHub Variable: HRMS_SMTP_FROM
HRMS_SMTP_FROM="YOUR HRMS SMTP FROM HERE"

# GitHub Variable: HRMS_DASHBOARD_URL
HRMS_DASHBOARD_URL="Your HRMS DASHBOARD URL HERE"

# ==================== AZURE EVENT HUB (API LOGGING) ====================
# GitHub Secret: EVENT_HUB_CONNECTION_STRING (SENSITIVE)
EVENT_HUB_CONNECTION_STRING="YOUR EVENT HUB CONNECTION STRING HERE"

# GitHub Variable: EVENT_HUB_NAME
EVENT_HUB_NAME="YOUR EVENT HUB NAME HERE"

# ==================== AZURE SERVICE BUS (LOGGING QUEUE) ====================
# GitHub Secret: AZURE_SERVICE_BUS_CONNECTION_STRING (SENSITIVE)
AZURE_SERVICE_BUS_CONNECTION_STRING="YOUR AZURE SERVICE BUS CONNECTION STRING HERE"

# GitHub Variable: AZURE_SERVICE_BUS_QUEUE_NAME
AZURE_SERVICE_BUS_QUEUE_NAME="YOUR AZURE SERVICE BUS QUEUE NAME HERE"

# ==================== LOGGING CONFIGURATION (Optional) ====================
# GitHub Variable: BATCH_SIZE (Optional)
BATCH_SIZE=1

# GitHub Variable: FLUSH_INTERVAL (Optional)
FLUSH_INTERVAL=30000

# GitHub Variable: SLOW_THRESHOLD (Optional)
SLOW_THRESHOLD=10000

# ==================== DATABASE CONFIGURATION ====================
# GitHub Variable: DATABASE_OUTPUT_NAME
DATABASE_OUTPUT_NAME=YOUR DATABASE NAME HERE

# GitHub Variable: DATABASE_OUTPUT_USER
DATABASE_OUTPUT_USER=YOUR DATABASE USER HERE

# GitHub Secret: DATABASE_OUTPUT_PASSWORD (SENSITIVE)
DATABASE_OUTPUT_PASSWORD=YOUR DATABASE PASSWORD HERE

# GitHub Variable: DATABASE_OUTPUT_PORT
DATABASE_OUTPUT_PORT=YOUR DATABASE PORT HERE

# GitHub Variable: DATABASE_OUTPUT_HOST
DATABASE_OUTPUT_HOST=YOUR DATABASE HOST HERE

# GitHub Variable: DATABASE_OUTPUT_DIALECT
DATABASE_OUTPUT_DIALECT=mysql

# ==================== CRON JOB CONFIGURATION ====================
# GitHub Variable: CRON_JOB_MACHINE_HOSTNAME
CRON_JOB_MACHINE_HOSTNAME=YOUR_MACHINE_HOSTNAME_HERE

# ==================== DOCKER CONFIGURATION ====================
# GitHub Variable: HOST_PORT (Optional, defaults to 5000)
HOST_PORT=5000
