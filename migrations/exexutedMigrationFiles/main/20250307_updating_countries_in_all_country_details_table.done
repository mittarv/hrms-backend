"use strict";

import { db, sequelize } from "../../models";
const { allCountryDetails: AllCountryDetails } = db;

module.exports = {
  up: async (queryInterface: any, Sequelize: any) => {
    console.log("Starting 'up' migration for updating countries in allCountryDetails table...");

    const transaction = await sequelize.transaction();

    try {
        console.log("updating 'allCountryDetails' table...");

        const duplicateRecord = await db.allCountryDetails.findOne({
          where: { countryIsoCode: 'SX' },
          order: [["id", "DESC"]]
        });

        if (duplicateRecord) {
          await db.allCountryDetails.destroy({
            where: {
              id: duplicateRecord.id
            }
          });
          console.log("Sint Maarten Duplicate record deleted successfully");
        } else {
          console.log('No Sint Maarten record found.');
        }

        const isleOfManRecordExists = await db.allCountryDetails.findOne({
          where: { countryIsoCode: 'IM', },
        });

        if (!isleOfManRecordExists) {

          const countryFlagSvg = "";
          const countryFlagSvgBuffer = Buffer.from(countryFlagSvg, 'base64');

          await AllCountryDetails.create({
              countryIsoCode: 'IM',
              countryIsoCodeAlpha3: 'IMN',
              countryName: 'Isle of Man',
              countryPhoneCode: '44',
              countryFlagSvg: countryFlagSvgBuffer,
              currencyName: 'Manx Pound',
              currencySymbol: '£',
              currencyCodeAlpha2: 'GB',
              currencyCodeAlpha3: 'IMP',
              transactionCurrencySymbol: '£',
              transactionCurrencyCodeAlpha3: 'IMP',
            },
            { transaction: transaction }
          );

          console.log("Isle of Man country added successfully");
        }
        else {
          console.log("Isle of Man country record already exists");
        }
        

        await transaction.commit();
        console.log("'allCountryDetails' table updated successfully");
    } catch (error) {
      await transaction.rollback();
      console.error("Error updating countries in 'allCountryDetails' table:", error);
    }
  },

  down: async (queryInterface: any, _: any) => {
    console.log("Starting 'down' migration for updating countries in 'allCountryDetails' table...");

    console.log("Deleting records from 'allCountryDetails' table...");

    const transaction = await sequelize.transaction();
    try {
    
      // Delete country 'Isle of Man' record
      await AllCountryDetails.destroy({
        where: {
          countryIsoCode: 'IM',
        },
        transaction: transaction,
      });

      await transaction.commit();
      console.log("Records deleted from table 'allCountryDetails' successfully.");
    } catch (error) {
      await transaction.rollback();
      console.error("Error deleting records from 'allCountryDetails' table: ", error);
    }
  },
};